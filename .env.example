# Database Configuration
SQLALCHEMY_DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/your_db_name
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

# JWT Configuration
SECRET_KEY=
ALGORITHM=HS256
KID=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=360

# OTP Configuration
OTP_EXPIRE_MINUTES=5

# Redis Configuration
REDIS_HOST=redis-1
REDIS_PORT=6379
REDIS_PASSWORD=redisPassword

# RabbitMQ Configuration
RABBIT_MQ_URL=amqp://lebe:admin321@rabbitmq/
RABBIT_MQ_ROUTING_KEY=
RABBIT_MQ_AUDIT_QUEUE=audit_queue
SMS_MQ_QUEUE=sms_queue
EMAIL_MQ_QUEUE=email_queue
BATCH_CUSTOMER_UPLOAD_QUEUE=batch_customer_upload_queue
COMPANY_QUEUE=company_creation_queue

# Frontend Configuration
BASE_FRONTEND_URL=https://lebeapp.com

# MongoDB Logging Configuration
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=api_logs_db

# Application Configuration
DEBUG=true
LOG_LEVEL=INFO
SERVICE_NAME=Lebe Backend

# Google Cloud Storage (if using cloud storage)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name

# Azure Blob Storage (if using Azure)
# Provide either an account connection string or set up Managed Identity / other auth.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=...;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=your-container-name

# Webhook Configuration
VERIFY_TOKEN=your_webhook_verify_token
META_API_KEY=your_meta_api_key

# ============================================
# PAYMENT GATEWAY CONFIGURATION (Orchard API)
# ============================================

# Orchard API Credentials
# Get these from your Orchard API dashboard
ORCHARD_API_KEY=your_orchard_api_key_here
ORCHARD_SECRET_KEY=your_orchard_secret_key_here
ORCHARD_SERVICE_ID=your_service_id_here

# Orchard API Base URL
ORCHARD_BASE_URL=https://orchard-api.anmgw.com

# Payment Callback Configuration


PAYMENT_CALLBACK_URL=https://your-api-domain.com/payments/callback

# ============================================
# PAYMENT PROCESSING CONFIGURATION
# ============================================

# Payment Request Timeout (seconds)
PAYMENT_TIMEOUT=30

# Minimum amounts for different transaction types (GHS)
MIN_AIRTIME_AMOUNT=0.2
MIN_MONEY_TRANSFER_AMOUNT=1.0
MIN_BILL_PAYMENT_AMOUNT=1.0

# Maximum amounts for fraud prevention (GHS)
MAX_AIRTIME_AMOUNT=500.0
MAX_MONEY_TRANSFER_AMOUNT=10000.0
MAX_BILL_PAYMENT_AMOUNT=10000.0

# OpenAI Configuration
OPENAI_API_KEY=

# Azure Storage
  AZURE_STORAGE_CONNECTION_STRING=
  AZURE_STORAGE_CONTAINER=

  # WhatsApp
WHATSAPP_PHONE_NUMBER_ID=

# ============================================
# PAYMENT STATUS CHECK CONFIGURATION
# ============================================

# Check interval in seconds (how often to check transaction status)
# Default: 30 seconds
# Example: 10, 15, 20, 30, 60
PAYMENT_CHECK_INTERVAL_SECONDS=30

# Maximum number of check attempts before marking payment as failed
# Default: 10 attempts
# Formula: Total wait time = PAYMENT_CHECK_INTERVAL_SECONDS * PAYMENT_CHECK_MAX_ATTEMPTS
# Default: 30s * 10 = 300s (5 minutes)
# Example: 6 (for 3 min), 10 (for 5 min), 20 (for 10 min)
PAYMENT_CHECK_MAX_ATTEMPTS=10

# Optional: Enable/disable payment status check service (default: true)
ENABLE_PAYMENT_STATUS_CHECK=true